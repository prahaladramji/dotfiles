[colors]
background = ${xrdb:background:#222}
foreground = ${xrdb:foreground:#dfdfdf}
black = ${xrdb:color0}
grey = ${xrdb:color8}
red = ${xrdb:color1}
bred = ${xrdb:color9}
green = ${xrdb:color2}
bgreen = ${xrdb:color10}
yellow = ${xrdb:color3}
byellow = ${xrdb:color11}
blue = ${xrdb:color4}
bblue = ${xrdb:color12}
magenta = ${xrdb:color5}
bmagenta = ${xrdb:color13}
cyan = ${xrdb:color6}
bcyan = ${xrdb:color14}
white = ${xrdb:color7}
bwhite = ${xrdb:color15}

[global/wm]
margin-top = 1
margin-bottom = 1

[bar/base]
monitor = ${env:MONITOR:DP-4}

width = 50%
height = 25
offset-x = 25%
offset-y = 0
line-size = 2
line-color = #f00
radius = 0.0
border-size = 0
border-color = #00000000
fixed-center = true
font-0 = PragmataPro Mono:pixelsize:10;2
background = ${colors.background}
foreground = ${colors.foreground}
tray-position = right

module-margin-left = 1
module-margin-right = 1

modules-left = bspwm 
modules-center = xwindow
modules-right = spotify memory cpu wlan date

click-left = 
click-middle = 
click-right =
scroll-up =
scroll-down =
double-click-left =
double-click-middle =
double-click-right =

[module/xwindow]
type = internal/xwindow
label = %title:0:50:...%

[module/bspwm]
type = internal/bspwm

ws-icon-0 = code;♚
ws-icon-1 = office;♛
ws-icon-2 = graphics;♜
ws-icon-3 = mail;♝
ws-icon-4 = web;♞
ws-icon-default = ♟

label-focused = %index%
label-focused-background = ${colors.white}
label-focused-underline= ${colors.blue}
label-focused-padding = 1

label-occupied = %index%
label-occupied-padding = 1

label-urgent = %index%!
label-urgent-background = ${colors.red}
label-urgent-padding = 1

label-empty = %index%
label-empty-foreground = ${colors.bwhite}
label-empty-padding = 1

[module/cpu]
type = internal/cpu
interval = 2
format = <ramp-load><label> 
format-underline = ${colors.yellow}
label = %percentage%%

ramp-load-0 = ▁
ramp-load-1 = ▂
ramp-load-2 = ▃
ramp-load-3 = ▄
ramp-load-4 = ▅
ramp-load-5 = ▆
ramp-load-6 = ▇
ramp-load-7 = █

[module/memory]
type = internal/memory
interval = 3
format = <label>
format-underline = ${colors.byellow}
label = %gb_used%

[module/date]
type = internal/date
interval = 5
date = " %Y-%m-%d"
time = %H:%M
format-underline = ${colors.magenta}

label = %date% %time%

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /
mount-1 = /home

label-mounted = %mountpoint%: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.bred}

[module/menu-apps]
type = custom/menu
format-spacing = 1

label-open = Shutdown
label-open-foreground = ${colors.red}
label-close =  cancel
label-close-foreground = ${colors.green}
label-separator = |
label-separator-foreground = ${colors.yellow}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[module/wlan]
type = internal/network
interface = wlp3s0
interval = 3.0
udspeed-minwidth = 5
accumulate-stats = true
format-connected = <ramp-signal> <label-connected>
format-disconnected = <label-disconnected>
format-connected-underline = ${colors.green}
format-disconnected-underline = ${colors.red}
label-connected = %essid%
label-disconnected = not connected
ramp-signal-0 = ▁
ramp-signal-1 = ▂
ramp-signal-2 = ▃
ramp-signal-3 = ▄
ramp-signal-4 = ▆
ramp-signal-5 = █

[module/spotify]
type = custom/script
exec = echo "$(~/bin/spotify-cli --status)"
tail = true
interval = 2
format-underline = ${colors.green}

[settings]
screenchange-reload = true