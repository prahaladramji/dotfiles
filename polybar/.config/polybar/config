[colors]
;BackGround = ${xrdb:background:#222}
BackGround = #e51d1f21
ForeGround = ${xrdb:foreground:#dfdfdf}
Black = ${xrdb:color0}
DarkGrey = ${xrdb:color8}
DarkRed = ${xrdb:color1}
Red = ${xrdb:color9}
DarkGreen = ${xrdb:color2}
Green = ${xrdb:color10}
DarkYellow = ${xrdb:color3}
Yellow = ${xrdb:color11}
DarkBlue = ${xrdb:color4}
Blue = ${xrdb:color12}
DarkMagenta = ${xrdb:color5}
Magenta = ${xrdb:color13}
DarkCyan = ${xrdb:color6}
Cyan = ${xrdb:color14}
LightGrey = ${xrdb:color7}
White = ${xrdb:color15}

[global/wm]
margin-top = 1
margin-bottom = 1

[bar/base]
monitor = ${env:MONITOR:DP-4}

width = 100%
height = 25
offset-x = 0
offset-y = 0
line-size = 2
line-color = #f00
radius = 0.0
border-size = 0
border-color = #00000000
fixed-center = true
font-0 = PragmataPro Mono:pixelsize:10;2
background = ${colors.BackGround}
foreground = ${colors.ForeGround}
tray-position = right
tray-background = ${colors.BackGround}

module-margin-left = 0
module-margin-right = 1

modules-left = bspwm
modules-center = xwindow
modules-right = spotify pavolume memory cpu wlan date menu-power blank

click-left = 
click-middle = 
click-right =
scroll-up =
scroll-down =
double-click-left =
double-click-middle =
double-click-right =

[module/xwindow]
type = internal/xwindow
label = %title:0:50:...%

[module/bspwm]
type = internal/bspwm

ws-icon-0 = code;♚
ws-icon-1 = office;♛
ws-icon-2 = graphics;♜
ws-icon-3 = mail;♝
ws-icon-4 = web;♞
ws-icon-default = ♟

label-focused = %index%
label-focused-background = ${colors.White}
label-focused-underline= ${colors.Blue}
label-focused-padding = 1

label-occupied = %index%
label-occupied-padding = 1

label-urgent = %index%!
label-urgent-background = ${colors.Red}
label-urgent-padding = 1

label-empty = %index%
label-empty-foreground = ${colors.LightGrey}
label-empty-padding = 1

[module/cpu]
type = internal/cpu
interval = 2
format = <ramp-load><label> 
format-underline = ${colors.Yellow}
label = %percentage%%

ramp-load-0 = ▁
ramp-load-1 = ▂
ramp-load-2 = ▃
ramp-load-3 = ▄
ramp-load-4 = ▅
ramp-load-5 = ▆
ramp-load-6 = ▇
ramp-load-7 = █

[module/memory]
type = internal/memory
interval = 3
format = <label>
format-underline = ${colors.Yellow}
label = %gb_used%

[module/date]
type = internal/date
interval = 5
date = "%a %d %b"
time = %H:%M
format-underline = ${colors.Magenta}

label = %date% %time%

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /
mount-1 = /home

label-mounted = %mountpoint%: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.Red}

[module/menu-power]
type = custom/menu
format-spacing = 1

label-open = Shutdown
label-open-foreground = ${colors.Red}
label-close =  cancel
label-close-foreground = ${colors.Green}
label-separator = |
label-separator-foreground = ${colors.Yellow}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[module/wlan]
type = internal/network
interface = wlp3s0
interval = 3.0
udspeed-minwidth = 5
accumulate-stats = true
format-connected = <ramp-signal> <label-connected>
format-disconnected = <label-disconnected>
format-connected-underline = ${colors.Green}
format-disconnected-underline = ${colors.Red}
label-connected = %essid%
label-disconnected = not connected
ramp-signal-0 = ▁
ramp-signal-1 = ▂
ramp-signal-2 = ▃
ramp-signal-3 = ▄
ramp-signal-4 = ▆
ramp-signal-5 = █

[module/pavolume]
type = custom/script
interval = 1
format-background = ${colors.BackGround}
format-underline = ${colors.Cyan}
format-padding = 0
label = %output%
exec = ~/.config/polybar/pavolume.sh
click-right = exec urxvt -name "pulsemixer" --geometry 120x10 -e zsh -c "pulsemixer"
click-left = ~/.config/polybar/pavolume.sh --togmute
scroll-up = ~/.config/polybar/pavolume.sh --up
scroll-down = ~/.config/polybar/pavolume.sh --down

[module/spotify]
type = custom/script
exec = echo "$(~/bin/spotify-cli --status)"
tail = true
interval = 2
format-underline = ${colors.Cyan}
click-left = spotify-cli --playpause
click-right = spotify-cli --next

[module/blank]
type = custom/text
content = "  "

[settings]
screenchange-reload = true
